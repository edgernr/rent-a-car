# ─────────────────────────────────────────────────────────────
# Silk Road Drive — environment template. Copy to .env and fill.
# ─────────────────────────────────────────────────────────────

# --- Database (PostgreSQL 16) ---
DATABASE_URL="postgresql://srd:srd@localhost:5432/srd?schema=public"

# --- Redis (BullMQ, rate-limit, cache) ---
REDIS_URL="redis://localhost:6379"

# --- API ---
API_PORT=4000
NODE_ENV=development
# Better Auth / sessions (generate a long random string)
AUTH_SECRET="change-me-to-a-long-random-secret"
# Public origins allowed to call the API (web + admin), comma-separated
CORS_ORIGINS="http://localhost:3000,http://localhost:5173"

# --- Object storage (MinIO, S3-compatible) ---
S3_ENDPOINT="http://localhost:9000"
S3_REGION="us-east-1"
S3_ACCESS_KEY="minioadmin"
S3_SECRET_KEY="minioadmin"
S3_BUCKET_PUBLIC="srd-public"
S3_BUCKET_PRIVATE="srd-private"

# --- Web (Next.js) ---
# Origin of the API (no /api/v1 suffix). The storefront proxies /api/* to this
# (Next.js rewrite) so the session cookie stays first-party. Defaults to localhost.
API_ORIGIN="http://localhost:4000"

# --- Admin (Vite) ---
# Admin calls a relative /api path; Vite proxies it in dev, vercel.json in prod.
# Nothing to set locally.

# --- Money / FX (display only; settlement is always UZS) ---
USD_INDICATIVE_RATE_UZS=12600

# --- Payments (placeholders — fill when rails are integrated) ---
CLICK_MERCHANT_ID=""
CLICK_SERVICE_ID=""
CLICK_SECRET_KEY=""
PAYME_MERCHANT_ID=""
PAYME_SECRET_KEY=""
